{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SkinDeck",
  "version": "0.1.0",
  "identifier": "com.skindeck.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer"
  },
  "app": {
    "windows": [
      {
        "title": "SkinDeck",
        "width": 275,
        "height": 348,
        "minWidth": 275,
        "minHeight": 120,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
